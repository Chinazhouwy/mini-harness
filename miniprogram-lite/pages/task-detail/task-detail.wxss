.detail-hero .title {
  font-size: 54rpx;
}

.hero-status {
  display: flex;
  gap: 14rpx;
  margin-top: 24rpx;
}

.quality-pass {
  background: rgba(255, 250, 240, 0.92);
  color: #1f6f4a;
}

.quality-fail {
  background: #fde9df;
  color: #a74435;
}

.error-card {
  margin-top: 24rpx;
  background: #fde9df;
  color: #a74435;
}

.quality-summary {
  display: block;
  color: #203a2d;
  font-size: 28rpx;
  font-weight: 700;
  line-height: 1.45;
}

.check-list {
  margin-top: 22rpx;
}

.check-row {
  display: flex;
  gap: 16rpx;
  padding: 12rpx 0;
  border-top: 1rpx solid rgba(32, 58, 45, 0.08);
  font-size: 25rpx;
}

.suggestions {
  margin-top: 18rpx;
  padding: 18rpx;
  border-radius: 18rpx;
  background: #f5eddc;
}

.suggestion {
  display: block;
  color: #5f533c;
  font-size: 24rpx;
  line-height: 1.6;
}

.mini-card {
  padding: 24rpx;
}

.strong {
  color: #17251e;
  font-size: 30rpx;
  font-weight: 850;
}

.mini-line {
  margin-top: 14rpx;
  color: #203a2d;
  font-size: 25rpx;
}

.reason {
  display: block;
  margin-top: 10rpx;
  font-size: 23rpx;
  line-height: 1.45;
}
