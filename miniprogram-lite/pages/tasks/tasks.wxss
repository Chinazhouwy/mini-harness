.compact-hero .title {
  font-size: 42rpx;
}

.error-card {
  margin-top: 24rpx;
  background: #fde9df;
  color: #a74435;
}

.task-card {
  transition: transform 0.18s ease;
}

.task-card:active {
  transform: scale(0.985);
}

.task-code {
  display: block;
  font-size: 36rpx;
  font-weight: 850;
}

.task-id {
  display: block;
  margin-top: 8rpx;
  font-size: 23rpx;
}

.task-range {
  margin-top: 18rpx;
  color: #536156;
  font-size: 25rpx;
}

.task-footer {
  display: flex;
  justify-content: space-between;
  gap: 12rpx;
  margin-top: 22rpx;
  padding-top: 18rpx;
  border-top: 1rpx solid rgba(32, 58, 45, 0.1);
  color: #203a2d;
  font-size: 24rpx;
}
