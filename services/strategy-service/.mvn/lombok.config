# Lombok 配置文件
# 此文件配置 Lombok 的行为

# 为所有构造函数添加 @ConstructorProperties
lombok.anyConstructor.addConstructorProperties = true

# 警告使用实验性功能
lombok.experimental.flagUsage = WARNING

# 复制 JPA 注解到生成的代码中
lombok.copyableAnnotations += jakarta.persistence.*
lombok.copyableAnnotations += javax.persistence.*

# 日志字段名称
lombok.log.fieldName = LOG

# 启用 Builder 的 toBuilder 功能
lombok.builder.className = *Builder

# 配置 Getter/Setter 前缀
lombok.getter.noIsPrefix = false

# 在生成的代码中禁用警告
lombok.singular.useGuava = false
lombok.singular.auto = true

# JPA 实体配置
config.stopBubbling = true
lombok.addJavaxGeneratedAnnotation = false
lombok.addLombokGeneratedAnnotation = true